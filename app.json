{
  "expo": {
    "name": "DS Engineering Enterprises",
    "slug": "ds-engineering",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo1.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/logo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./src/assets/logo1.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bazee.dsengineering"
    },
    "web": {
      "favicon": "./src/assets/logo1.png"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
